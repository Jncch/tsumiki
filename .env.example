# tsumiki LLM 接続設定（プロバイダ非依存、OpenAI 互換ベース + Azure OpenAI）
#
# 設計（CLAUDE.md §3）:
# - アプリ本体は OpenAI / AzureOpenAI SDK 経由で LLM を呼ぶ（プロバイダ非依存の設定層）。
# - ローカル (ollama) と クラウド の切替は LLM_PROVIDER + 各種 URL/key/model 環境変数で完結する。
# - `.env` 本体は .gitignore で除外。追跡するのは本ファイル (.env.example) のみ。
#
# 使い方:
#   1) cp .env.example .env
#   2) 下の「想定プロバイダ別の設定例」から 1 つ選び、該当ブロックの値を .env に反映
#   3) API キーを設定（.env のみ、決してコミットしない）
#   4) experiments/run_phase1_dryrun.py 等を引数なしで起動すれば .env が反映される
#
# プロバイダ切替:
#   LLM_PROVIDER=openai_compatible (デフォルト) → ollama / OpenAI / Anthropic / OpenRouter / Gemini
#   LLM_PROVIDER=azure_openai                   → Azure OpenAI（AZURE_OPENAI_* 変数を使う）

# ---------------------------------------------------------------------------
# 共通設定
# ---------------------------------------------------------------------------

LLM_TEMPERATURE=0.0
LLM_PROVIDER=openai_compatible

# MLflow tracking 先（プロジェクト内ファイルストア）
MLFLOW_TRACKING_URI=file:./mlruns

# ollama モデル保存先（プロジェクト内固定、CLAUDE.md §3）
# ollama をホスト起動する前にエクスポートすること
OLLAMA_MODELS=./var/ollama/models


# ---------------------------------------------------------------------------
# 想定プロバイダ別の設定例 — どれか 1 つを採用し、他はコメントアウトのまま
# ---------------------------------------------------------------------------

# [A] ローカル ollama（開発・探索ループの主用途、LLM_PROVIDER=openai_compatible）
#   - コンテナ内から呼ぶ場合: http://host.docker.internal:11434/v1
#   - ホストから呼ぶ場合:     http://localhost:11434/v1
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=hf.co/bartowski/Qwen2.5-14B-Instruct-GGUF:Q4_K_M

# [B] Azure OpenAI（クラウド強モデル、最終確認用）
#   LLM_PROVIDER=azure_openai に変更してから下を有効化する。
#   エンドポイントは Azure ポータル「リソース管理 > キーとエンドポイント」から取得。
#   デプロイ名は「リソース管理 > モデル デプロイ」で作成したデプロイの名前
#   （モデル名と別概念。例: モデル gpt-4o をデプロイ名 my-gpt-4o で展開した場合は my-gpt-4o）。
#   API バージョンは https://learn.microsoft.com/azure/ai-services/openai/reference 参照。
# LLM_PROVIDER=azure_openai
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_DEPLOYMENT=<your-deployment-name>
# AZURE_OPENAI_API_VERSION=2024-10-21

# [C] OpenAI（クラウド強モデル、LLM_PROVIDER=openai_compatible）
#   API キーは https://platform.openai.com/api-keys から発行
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-5

# [D] Anthropic Claude（クラウド強モデル、LLM_PROVIDER=openai_compatible）
#   OpenAI 互換エンドポイント (https://docs.anthropic.com/ja/api/openai-sdk) を使う。
#   API キーは https://console.anthropic.com/settings/keys から発行
#   注意: 一部機能（structured outputs, parallel tool calls 等）は OpenAI 互換層では使えない。
#         tsumiki は plain chat completion のみ使うため影響なし。
# LLM_BASE_URL=https://api.anthropic.com/v1/
# LLM_API_KEY=sk-ant-...
# LLM_MODEL=claude-opus-4-7
#   代替モデル: claude-sonnet-4-6, claude-haiku-4-5

# [E] OpenRouter（OpenAI 互換、複数プロバイダを横断したい場合）
#   モデル名は https://openrouter.ai/models から
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-...
# LLM_MODEL=anthropic/claude-opus-4-7

# [F] Google Gemini（OpenAI 互換エンドポイント）
#   詳細: https://ai.google.dev/gemini-api/docs/openai
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_API_KEY=AIza...
# LLM_MODEL=gemini-2.5-pro
